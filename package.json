{
    "name": "@erag/text-editor-vue",
    "version": "0.2.44",
    "description": "A dependency-free Vue 3 rich text editor built with native browser APIs, flexible configuration, and full TypeScript support.",
    "type": "module",
    "license": "MIT",
    "author": "Amit Gupta",
    "repository": {
        "type": "git",
        "url": "https://github.com/eramitgupta/text-editor-vue.git"
    },
    "bugs": {
        "url": "https://github.com/eramitgupta/text-editor-vue/issues"
    },
    "homepage": "https://github.com/eramitgupta/text-editor-vue#readme",
    "keywords": [
        "vue",
        "vue3",
        "editor",
        "rich-text",
        "wysiwyg",
        "typescript"
    ],
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "main": "./dist/text-editor-vue.js",
    "module": "./dist/text-editor-vue.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/text-editor-vue.js"
        },
        "./style.css": "./dist/style.css"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build",
        "format": "prettier --write src eslint.config.js vite.config.ts package.json README.md",
        "format:check": "prettier --check src eslint.config.js vite.config.ts package.json README.md",
        "lint": "eslint src vite.config.ts",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "prepublishOnly": "npm run format:check && npm run lint && npm run typecheck && npm run build"
    },
    "peerDependencies": {
        "vue": ">=3.5.0 <4"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.0",
        "@babel/eslint-parser": "^7.28.0",
        "@babel/preset-typescript": "^7.28.0",
        "@typescript/typescript6": "^6.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "eslint": "^9.39.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.0.0",
        "globals": "^16.0.0",
        "prettier": "^3.6.2",
        "typescript": "^7.0.0",
        "vite": "^8.0.0",
        "vite-plugin-dts": "^5.0.0",
        "vue-eslint-parser": "^10.0.0"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
