{
    "name": "@erag/text-editor-vue",
    "version": "0.1.0",
    "description": "A modern dependency-free Vue 3 rich text editor (WYSIWYG) built with native browser APIs. Supports TypeScript, mentions, merge tags, templates, image upload, tables, HTML editing, and customizable toolbars.",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Er Amit Gupta",
        "url": "https://github.com/eramitgupta"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/eramitgupta/text-editor-vue.git"
    },
    "bugs": {
        "url": "https://github.com/eramitgupta/text-editor-vue/issues"
    },
    "homepage": "https://erag.in/text-editor-vue/index.html",
    "keywords": [
        "vue",
        "vue3",
        "vue-editor",
        "vue-rich-text-editor",
        "rich-text-editor",
        "text-editor",
        "wysiwyg",
        "wysiwyg-editor",
        "html-editor",
        "contenteditable",
        "typescript",
        "dependency-free",
        "zero-dependencies",
        "native-browser-api",
        "open-source",
        "free",
        "pro-features",
        "enterprise-ready",
        "customizable",
        "toolbar",
        "mentions",
        "merge-tags",
        "templates",
        "email-templates",
        "image-upload",
        "media-upload",
        "table-editor",
        "document-editor",
        "email-editor",
        "cms-editor",
        "vite"
    ],
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "main": "./dist/text-editor-vue.js",
    "module": "./dist/text-editor-vue.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/text-editor-vue.js"
        },
        "./style.css": "./dist/style.css"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build",
        "lint": "prettier --write src eslint.config.js vite.config.ts package.json \"*.md\" \".github/**/*.md\" && eslint src vite.config.ts --fix",
        "lint:check": "prettier --check src eslint.config.js vite.config.ts package.json \"*.md\" \".github/**/*.md\" && eslint src vite.config.ts",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "prepublishOnly": "npm run lint:check && npm run typecheck && npm run build"
    },
    "peerDependencies": {
        "vue": ">=3.5.0 <4"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^7.28.0",
        "@babel/preset-typescript": "^7.28.0",
        "@eslint/js": "^9.39.0",
        "@types/node": "^24.13.3",
        "@typescript/typescript6": "^6.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/language-core": "^3.3.7",
        "eslint": "^9.39.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.0.0",
        "globals": "^16.0.0",
        "prettier": "^3.6.2",
        "typescript": "^7.0.0",
        "vite": "^8.0.0",
        "vite-plugin-dts": "^5.0.0",
        "vue-eslint-parser": "^10.0.0"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
